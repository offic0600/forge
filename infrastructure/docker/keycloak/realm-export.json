{
  "id": "forge",
  "realm": "forge",
  "displayName": "Forge Platform",
  "enabled": true,
  "sslRequired": "none",
  "registrationAllowed": false,
  "loginWithEmailAllowed": true,
  "duplicateEmailsAllowed": false,
  "resetPasswordAllowed": true,
  "editUsernameAllowed": false,
  "bruteForceProtected": true,
  "roles": {
    "realm": [
      {
        "name": "admin",
        "description": "Full platform administrator"
      },
      {
        "name": "developer",
        "description": "Developer with full IDE access"
      },
      {
        "name": "viewer",
        "description": "Read-only access to workspaces and knowledge"
      }
    ]
  },
  "users": [
    {
      "username": "admin",
      "email": "admin@forge.dev",
      "firstName": "Admin",
      "lastName": "User",
      "enabled": true,
      "emailVerified": true,
      "credentials": [
        {
          "type": "password",
          "value": "admin",
          "temporary": false
        }
      ],
      "realmRoles": [
        "admin",
        "developer"
      ]
    },
    {
      "username": "dev1",
      "email": "dev1@forge.dev",
      "firstName": "Developer",
      "lastName": "One",
      "enabled": true,
      "emailVerified": true,
      "credentials": [
        {
          "type": "password",
          "value": "dev1",
          "temporary": false
        }
      ],
      "realmRoles": [
        "developer"
      ]
    },
    {
      "username": "viewer1",
      "email": "viewer1@forge.dev",
      "firstName": "Viewer",
      "lastName": "One",
      "enabled": true,
      "emailVerified": true,
      "credentials": [
        {
          "type": "password",
          "value": "viewer1",
          "temporary": false
        }
      ],
      "realmRoles": [
        "viewer"
      ]
    }
  ],
  "clients": [
    {
      "clientId": "forge-web-ide",
      "name": "Forge Web IDE",
      "enabled": true,
      "publicClient": true,
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": true,
      "rootUrl": "http://localhost:9000",
      "baseUrl": "/",
      "redirectUris": [
        "http://localhost:9000/*",
        "http://localhost:3000/*",
        "http://localhost:19000/*"
      ],
      "webOrigins": [
        "http://localhost:9000",
        "http://localhost:3000",
        "http://localhost:19000"
      ],
      "protocol": "openid-connect",
      "attributes": {
        "pkce.code.challenge.method": "S256",
        "post.logout.redirect.uris": "http://localhost:9000/*"
      },
      "defaultClientScopes": [
        "openid",
        "profile",
        "email",
        "roles"
      ]
    },
    {
      "clientId": "forge-enterprise",
      "name": "Forge Enterprise Console",
      "enabled": true,
      "publicClient": false,
      "secret": "enterprise-secret",
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": false,
      "rootUrl": "http://localhost:19001",
      "baseUrl": "/",
      "redirectUris": [
        "http://localhost:19001/*",
        "http://forge-enterprise-console:3000/*"
      ],
      "webOrigins": [
        "http://localhost:19001"
      ],
      "protocol": "openid-connect",
      "attributes": {
        "post.logout.redirect.uris": "http://localhost:19001/*"
      },
      "defaultClientScopes": [
        "openid",
        "profile",
        "email",
        "roles"
      ]
    }
  ],
  "clientScopes": [
    {
      "name": "roles",
      "protocol": "openid-connect",
      "attributes": {
        "include.in.token.scope": "true"
      },
      "protocolMappers": [
        {
          "name": "realm roles",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-realm-role-mapper",
          "consentRequired": false,
          "config": {
            "multivalued": "true",
            "userinfo.token.claim": "true",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "claim.name": "realm_roles",
            "jsonType.label": "String"
          }
        }
      ]
    }
  ]
}