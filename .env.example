# Forge Platform 环境变量配置
# 复制此文件为 .env 并填入实际值
# .env 已加入 .gitignore，不会被提交
#
# 至少配置一个 Provider 的 API Key 即可使用平台

# ============================================================
# Provider 1: Anthropic（Claude 系列）
# ============================================================
# 获取方式: https://console.anthropic.com/settings/keys
# 支持模型: claude-opus-4-6, claude-sonnet-4-6, claude-haiku-4-5
ANTHROPIC_API_KEY=sk-ant-api03-xxxx

# ============================================================
# Provider 2: Google Gemini
# ============================================================
# 获取方式: https://aistudio.google.com/apikey
# 支持模型: gemini-2.5-pro, gemini-2.5-flash, gemini-2.5-flash-lite
# GEMINI_API_KEY=AIza...

# ============================================================
# Provider 3: 阿里云 DashScope（通义千问系列）
# ============================================================
# 获取方式: https://dashscope.console.aliyun.com/apiKey
# 支持模型: qwen3.5-plus, qwen-plus, qwen-turbo, qwen-long
# DASHSCOPE_API_KEY=sk-...

# ============================================================
# Provider 4: AWS Bedrock（Claude via AWS）
# ============================================================
# 需要 AWS IAM 凭证，支持 AWS_PROFILE 或 AccessKey 方式
# 支持模型: anthropic.claude-opus-4-6-v1, anthropic.claude-sonnet-4-6,
#           anthropic.claude-haiku-4-5-20251001-v1:0
# AWS_REGION=us-east-1
# AWS_PROFILE=default
# 或使用 AccessKey:
# AWS_ACCESS_KEY_ID=AKIA...
# AWS_SECRET_ACCESS_KEY=...

# ============================================================
# Provider 5: OpenAI 兼容接口（Ollama / vLLM / LocalAI 等）
# ============================================================
# 适用于任何兼容 OpenAI Chat Completions API 的服务
# LOCAL_MODEL_URL=http://localhost:11434
# LOCAL_MODEL_NAME=llama3.1:8b
# LOCAL_MODEL_API_KEY=optional-key

# ============================================================
# 安全配置
# ============================================================
# API Key 加密密钥（用于加密存储用户配置的 API Key）
# 生成方式: openssl rand -base64 32
# FORGE_ENCRYPTION_KEY=your-base64-encryption-key

# 是否启用 Keycloak 认证（试用模式建议 false）
FORGE_SECURITY_ENABLED=false
